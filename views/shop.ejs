<%- include('partials/header', { title: 'Shop', page: 'shop', searchQuery }) %>

<div class="section" style="padding-top:2rem">
  <!-- Header -->
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:2rem">
    <div>
      <h1 style="font-family:'Nunito',sans-serif;font-size:2rem;font-weight:900">
        <% if (searchQuery) { %>
          🔍 Results for "<%= searchQuery %>"
        <% } else if (activeCategory) { %>
          🏠 <%= activeCategory %>
        <% } else { %>
          🛍️ All Products
        <% } %>
      </h1>
      <p style="color:var(--gray);margin-top:0.3rem"><%= products.length %> product<%= products.length !== 1 ? 's' : '' %> found</p>
    </div>
    <% if (searchQuery || activeCategory) { %>
      <a href="/shop" class="btn btn-outline" style="color:var(--dark);border-color:var(--border)">✕ Clear Filter</a>
    <% } %>
  </div>

  <!-- Category Pills -->
  <div style="display:flex;gap:0.8rem;flex-wrap:wrap;margin-bottom:2rem">
    <a href="/shop" class="cat-pill <%= !activeCategory ? 'active' : '' %>">All</a>
    <% categories.forEach(cat => { %>
      <a href="/shop?category=<%= encodeURIComponent(cat) %>" class="cat-pill <%= activeCategory === cat ? 'active' : '' %>"><%= cat %></a>
    <% }) %>
  </div>

  <!-- Products -->
  <div class="product-grid">
    <% if (products.length === 0) { %>
      <div class="no-results">
        <span>😕</span>
        <h3>No products found</h3>
        <p>Try a different search term or browse all products.</p>
        <a href="/shop" class="btn btn-primary" style="margin-top:1rem">View All</a>
      </div>
    <% } else { %>
      <% products.forEach(product => { %>
        <%- include('partials/product-card', { product }) %>
      <% }) %>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
