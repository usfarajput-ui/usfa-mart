<%- include('partials/header', { title: 'Home', page: 'home' }) %>

<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <div class="hero-badge">🇵🇰 Pakistan's Favourite Home Store</div>
    <h1>Make Your Home <span class="highlight">Beautiful</span> & Cozy</h1>
    <p>Shop premium home decor & daily essentials at unbeatable prices. Fast delivery across Pakistan with Cash on Delivery available.</p>
    <div class="hero-btns">
      <a href="/shop" class="btn btn-primary">🛍️ Shop Now</a>
      <a href="https://wa.me/923001234567" target="_blank" class="btn btn-outline">💬 WhatsApp Order</a>
    </div>
  </div>
</section>

<!-- CATEGORIES -->
<div class="categories-strip">
  <div class="cat-inner">
    <span class="cat-label">Browse:</span>
    <a href="/shop" class="cat-pill active">All Products</a>
    <% categories.forEach(cat => { %>
      <a href="/shop?category=<%= encodeURIComponent(cat) %>" class="cat-pill"><%= cat %></a>
    <% }) %>
  </div>
</div>

<!-- FEATURED PRODUCTS -->
<div class="section">
  <div class="section-header">
    <span class="section-label">✨ Hand-picked for you</span>
    <h2>Featured Products</h2>
    <p>Discover our most loved home essentials</p>
  </div>
  <div class="product-grid">
    <% featured.forEach(product => { %>
      <%- include('partials/product-card', { product }) %>
    <% }) %>
  </div>
  <div style="text-align:center;margin-top:2.5rem">
    <a href="/shop" class="btn btn-primary">View All Products →</a>
  </div>
</div>

<!-- FEATURES BAND -->
<div class="features-band">
  <div class="features-inner">
    <div class="feature-item">
      <span class="feature-icon">🚚</span>
      <h4>Fast Delivery</h4>
      <p>Across all major cities in Pakistan</p>
    </div>
    <div class="feature-item">
      <span class="feature-icon">💰</span>
      <h4>Cash on Delivery</h4>
      <p>Pay when you receive your order</p>
    </div>
    <div class="feature-item">
      <span class="feature-icon">💬</span>
      <h4>WhatsApp Support</h4>
      <p>Order & track via WhatsApp 24/7</p>
    </div>
    <div class="feature-item">
      <span class="feature-icon">✅</span>
      <h4>Quality Guaranteed</h4>
      <p>100% authentic & quality products</p>
    </div>
  </div>
</div>

<!-- ALL PRODUCTS -->
<div class="section">
  <div class="section-header">
    <span class="section-label">🏠 Full Collection</span>
    <h2>All Products</h2>
    <p>Everything your home needs, all in one place</p>
  </div>
  <div class="product-grid">
    <% products.forEach(product => { %>
      <%- include('partials/product-card', { product }) %>
    <% }) %>
  </div>
</div>

<%- include('partials/footer') %>
