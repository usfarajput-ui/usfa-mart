<div class="product-card">
  <div class="product-img-wrap">
    <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy">
    <% if (product.badge) { %>
      <span class="product-badge" style="background:<%= product.badgeColor %>"><%= product.badge %></span>
    <% } %>
  </div>
  <div class="product-body">
    <div class="product-category"><%= product.category %></div>
    <div class="product-name"><%= product.name %></div>
    <div class="product-price-row">
      <span class="price-current">Rs. <%= product.price.toLocaleString() %></span>
      <span class="price-old">Rs. <%= product.originalPrice.toLocaleString() %></span>
      <span class="price-save"><%=  Math.round((1 - product.price/product.originalPrice)*100) %>% off</span>
    </div>
    <div class="card-actions">
      <button class="btn-cart" onclick='Cart.add(<%= JSON.stringify(product) %>)'>🛒 Add to Cart</button>
      <a href="/product/<%= product.id %>" class="btn-view">👁️</a>
      <button class="btn-wa" onclick="openWhatsAppProduct('<%= product.name %>', <%= product.price %>)" title="Order via WhatsApp">💬</button>
    </div>
  </div>
</div>
