<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>Usfa Mart</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🛍️</text></svg>">
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar">
  <div class="nav-inner">
    <a href="/" class="nav-logo">Usfa<span>Mart</span></a>

    <form class="nav-search" action="/shop" method="GET">
      <input type="text" name="search" placeholder="Search products..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
      <button type="submit">🔍</button>
    </form>

    <ul class="nav-links">
      <li><a href="/" class="<%= typeof page !== 'undefined' && page === 'home' ? 'active' : '' %>">Home</a></li>
      <li><a href="/shop" class="<%= typeof page !== 'undefined' && page === 'shop' ? 'active' : '' %>">Shop</a></li>
      <li><a href="/contact" class="<%= typeof page !== 'undefined' && page === 'contact' ? 'active' : '' %>">Contact</a></li>
      <li>
        <a href="/cart" class="cart-btn">
          🛒 Cart
          <span class="cart-count" style="display:none">0</span>
        </a>
      </li>
    </ul>
  </div>
</nav>
