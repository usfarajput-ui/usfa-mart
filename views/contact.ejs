<%- include('partials/header', { title: 'Contact Us', page: 'contact' }) %>

<div class="contact-page" style="padding-top:2rem;padding-bottom:4rem">
  <div class="contact-card">
    <h1>📬 Contact Us</h1>
    <p>Have a question or need help? We're here for you. You can also reach us directly on WhatsApp for faster replies!</p>

    <% if (success) { %>
      <div class="success-msg">✅ Message sent! We'll get back to you within 24 hours.</div>
    <% } %>

    <form method="POST" action="/contact">
      <div class="form-group">
        <label for="name">Your Name</label>
        <input type="text" id="name" name="name" placeholder="e.g. Ahmed Khan" required>
      </div>
      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" id="email" name="email" placeholder="you@example.com" required>
      </div>
      <div class="form-group">
        <label for="message">Message</label>
        <textarea id="message" name="message" placeholder="Write your question or order inquiry here..." required></textarea>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;border-radius:8px">
        📨 Send Message
      </button>
    </form>

    <div class="contact-info">
      <a href="https://wa.me/923001234567" target="_blank" class="info-chip">💬 WhatsApp: 0300-1234567</a>
      <a href="tel:+923001234567" class="info-chip">📞 Call Us</a>
      <a href="mailto:info@usfamart.pk" class="info-chip">📧 Email Us</a>
      <span class="info-chip">📍 Lahore, Pakistan</span>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
