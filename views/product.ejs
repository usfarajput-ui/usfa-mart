<%- include('partials/header', { title: product.name, page: 'shop' }) %>

<div class="product-detail">
  <!-- Breadcrumb -->
  <div style="margin-bottom:1.5rem;font-size:0.9rem;color:var(--gray)">
    <a href="/" style="color:var(--gray);text-decoration:none">Home</a> /
    <a href="/shop" style="color:var(--gray);text-decoration:none">Shop</a> /
    <a href="/shop?category=<%= encodeURIComponent(product.category) %>" style="color:var(--gray);text-decoration:none"><%= product.category %></a> /
    <span style="color:var(--dark)"><%= product.name %></span>
  </div>

  <div class="detail-grid">
    <!-- Image -->
    <div class="detail-img">
      <img src="<%= product.image %>" alt="<%= product.name %>">
      <% if (product.badge) { %>
        <div style="margin-top:1rem">
          <span class="product-badge" style="background:<%= product.badgeColor %>;position:static"><%= product.badge %></span>
        </div>
      <% } %>
    </div>

    <!-- Info -->
    <div class="detail-info">
      <div class="detail-category"><%= product.category %></div>
      <h1 class="detail-name"><%= product.name %></h1>

      <div class="detail-price-row">
        <span class="detail-price">Rs. <%= product.price.toLocaleString() %></span>
        <span class="detail-original">Rs. <%= product.originalPrice.toLocaleString() %></span>
        <span class="price-save"><%= Math.round((1 - product.price/product.originalPrice)*100) %>% OFF</span>
      </div>

      <p class="detail-desc"><%= product.description %></p>

      <div style="background:var(--light-bg);border-radius:var(--radius-sm);padding:1rem;margin-bottom:1.5rem">
        <div style="display:flex;gap:2rem;flex-wrap:wrap">
          <div><span style="font-size:1.2rem">🚚</span> <strong>Free Delivery</strong></div>
          <div><span style="font-size:1.2rem">💰</span> <strong>Cash on Delivery</strong></div>
          <div><span style="font-size:1.2rem">✅</span> <strong>Quality Assured</strong></div>
        </div>
      </div>

      <div class="detail-actions">
        <button class="btn btn-primary" onclick='Cart.add(<%= JSON.stringify(product) %>)'>🛒 Add to Cart</button>
        <a href="/cart" class="btn" style="background:var(--dark);color:white">🧾 View Cart</a>
        <button class="btn" style="background:#25d366;color:white" onclick="openWhatsAppProduct('<%= product.name %>', <%= product.price %>)">💬 WhatsApp Order</button>
      </div>
    </div>
  </div>

  <!-- Related Products -->
  <% if (related.length > 0) { %>
    <div style="margin-top:3rem">
      <div class="section-header" style="text-align:left;margin-bottom:1.5rem">
        <span class="section-label">You might also like</span>
        <h2 style="font-size:1.8rem">Related Products</h2>
      </div>
      <div class="product-grid">
        <% related.forEach(p => { %>
          <%- include('partials/product-card', { product: p }) %>
        <% }) %>
      </div>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
