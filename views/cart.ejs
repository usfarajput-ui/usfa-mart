<%- include('partials/header', { title: 'My Cart', page: '' }) %>

<div class="cart-page">
  <h1>🛒 My Cart</h1>

  <!-- Empty state -->
  <div id="cart-empty" class="cart-empty" style="display:none">
    <span class="emoji">🛍️</span>
    <h3>Your cart is empty</h3>
    <p>Add some beautiful products to get started!</p>
    <a href="/shop" class="btn btn-primary">Shop Now</a>
  </div>

  <!-- Cart Items -->
  <div id="cart-items"></div>

  <!-- Summary -->
  <div id="cart-summary" style="display:none" class="cart-summary">
    <h3 style="margin-bottom:1rem;font-family:'Nunito',sans-serif;font-weight:800">Order Summary</h3>

    <div class="summary-row">
      <span>Subtotal</span>
      <span id="summary-subtotal">Rs. 0</span>
    </div>
    <div class="summary-row">
      <span>Delivery</span>
      <span id="summary-shipping">FREE</span>
    </div>
    <div class="summary-row total">
      <span>Total</span>
      <span id="summary-total">Rs. 0</span>
    </div>

    <div style="margin-top:1rem;padding:0.8rem;background:#fff3cd;border-radius:8px;font-size:0.85rem;color:#856404;font-weight:600">
      🚚 Free delivery on all orders | Cash on Delivery available
    </div>

    <div class="checkout-btns">
      <button class="btn-whatsapp-order" onclick="openWhatsAppOrder()">
        💬 Order via WhatsApp
      </button>
      <button class="btn-cod" onclick="codCheckout()">
        💰 Cash on Delivery — Place Order
      </button>
      <a href="/shop" style="text-align:center;color:var(--gray);font-size:0.9rem;text-decoration:none;padding:0.5rem">← Continue Shopping</a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
